# Cloudflare Turnstile site key (public key — safe to expose to the browser)
# Get from https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# URL for the Authentik OIDC login page (used as the Login button href)
VITE_LOGIN_URL=/auth/oidc/authentik/login/
