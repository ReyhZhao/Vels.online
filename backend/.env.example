SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
DATABASE_URL=postgres://vels:vels_password@db:5432/vels_online
REDIS_URL=redis://valkey:6379/0

# AUTHENTIK_SERVER_URL: OIDC application discovery URL (e.g. https://authentik.example.com/application/o/<app-slug>/)
# AUTHENTIK_API_URL: root Authentik server URL used for Admin API calls (e.g. https://authentik.example.com)
AUTHENTIK_CLIENT_ID=your-client-id
AUTHENTIK_CLIENT_SECRET=your-client-secret
AUTHENTIK_SERVER_URL=https://authentik.example.com/application/o/your-app-slug/
AUTHENTIK_API_URL=https://authentik.example.com
AUTHENTIK_API_TOKEN=your-authentik-api-token
AUTHENTIK_ENROLLMENT_FLOW_SLUG=enrollment

# Set EMAIL_SSL_NO_VERIFY=True when the SMTP relay is a cluster-internal service
# whose hostname doesn't match its TLS certificate (e.g. Mailu on Kubernetes).
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-smtp-user
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=noreply@example.com
EMAIL_SSL_NO_VERIFY=False

TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret-key
UPTIMEROBOT_API_KEY=test12345

WASABI_ENDPOINT=https://s3.eu-west-1.wasabisys.com
WASABI_BUCKET=your-bucket-name
WASABI_ACCESS_KEY=your-access-key
WASABI_SECRET_KEY=your-secret-key

WAZUH_API_URL=https://wazuh.wazuh.svc.cluster.local:55000
WAZUH_API_USER=your-wazuh-api-user
WAZUH_API_PASSWORD=your-wazuh-api-password
WAZUH_MANAGER_HOST=wazuh.example.com
WAZUH_AGENT_VERSION=4.12.0-1
WAZUH_REGISTRATION_PASSWORD=your-wazuh-registration-password

WAZUH_INDEXER_URL=https://wazuh-indexer.wazuh.svc.cluster.local:9200
WAZUH_INDEXER_USER=your-indexer-user
WAZUH_INDEXER_PASSWORD=your-indexer-password

# SEMAPHORE_URL: base URL of your Semaphore (Ansible) server (e.g. https://semaphore.example.com)
# SEMAPHORE_PROJECT_ID: numeric ID of the project that owns the automation templates
SEMAPHORE_URL=https://semaphore.example.com
SEMAPHORE_API_TOKEN=your-semaphore-api-token
SEMAPHORE_PROJECT_ID=1

# LLM provider for exception rule generation (defaults to Gemini)
# Set EXCEPTION_LLM_PROVIDER=exceptions.llm.ollama.OllamaProvider to use Ollama instead
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
EXCEPTION_LLM_PROVIDER=exceptions.llm.gemini.GeminiFlashProvider
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_API_KEY=