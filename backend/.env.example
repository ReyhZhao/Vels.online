SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
DATABASE_URL=postgres://vels:vels_password@db:5432/vels_online
REDIS_URL=redis://valkey:6379/0

# AUTHENTIK_SERVER_URL: OIDC application discovery URL (e.g. https://authentik.example.com/application/o/<app-slug>/)
# AUTHENTIK_API_URL: root Authentik server URL used for Admin API calls (e.g. https://authentik.example.com)
AUTHENTIK_CLIENT_ID=your-client-id
AUTHENTIK_CLIENT_SECRET=your-client-secret
AUTHENTIK_SERVER_URL=https://authentik.example.com/application/o/your-app-slug/
AUTHENTIK_API_URL=https://authentik.example.com
AUTHENTIK_API_TOKEN=your-authentik-api-token
AUTHENTIK_ENROLLMENT_FLOW_SLUG=enrollment

TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret-key
UPTIMEROBOT_API_KEY=test12345

WASABI_ENDPOINT=https://s3.eu-west-1.wasabisys.com
WASABI_BUCKET=your-bucket-name
WASABI_ACCESS_KEY=your-access-key
WASABI_SECRET_KEY=your-secret-key

WAZUH_API_URL=https://wazuh.wazuh.svc.cluster.local:55000
WAZUH_API_USER=your-wazuh-api-user
WAZUH_API_PASSWORD=your-wazuh-api-password
WAZUH_MANAGER_HOST=wazuh.example.com

WAZUH_INDEXER_URL=https://wazuh-indexer.wazuh.svc.cluster.local:9200
WAZUH_INDEXER_USER=your-indexer-user
WAZUH_INDEXER_PASSWORD=your-indexer-password